SELECT SINGLE bstkd INTO purch_no FROM vbkd WHERE vbeln =
                      LS_BIL_INVOICE-HD_REF-ORDER_NUMB.

DATA : VDT(2) TYPE C,VMN(2) TYPE C,VYR(4) TYPE C.

 VDT = LS_BIL_INVOICE-HD_REF-PURCH_DATE+6(2).
 VMN = LS_BIL_INVOICE-HD_REF-PURCH_DATE+4(2).
 VYR = LS_BIL_INVOICE-HD_REF-PURCH_DATE+0(4).

 CONCATENATE VYR '-' VMN '-' VDT INTO GVPODT.





















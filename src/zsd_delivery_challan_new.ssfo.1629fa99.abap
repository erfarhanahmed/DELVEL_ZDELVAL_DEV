IF GS_MSEG-MATNR IS NOT INITIAL.
 SELECT SINGLE KNUMH
      FROM A994
      INTO @DATA(LV_KNUMH)
      WHERE MATNR = @GS_MSEG-MATNR
      AND WERKS = @GS_MSEG-WERKS
      AND   KSCHL = 'ZSUB'
    and datbi = '99991231'
     AND KFRST = ' '.

   SELECT SINGLE KBETR
              FROM KONP
              INTO LV_KBETR
              WHERE KNUMH = LV_KNUMH.

*BREAK-POINT.

  LV_GROSS = LV_GROSS + LV_KBETR .

*  CLEAR LV_KBETR.
LV_VAT = LV_GROSS * 15 / 100.
ENDIF.

LV_KBETR1 = LV_KBETR.



BREAK primus.
V_IND = V_IND + 1.
CLEAR GS_IT_QM.
READ TABLE
IS_DLV_DELNOTE-IT_QM INTO GS_IT_QM
WITH KEY DELIV_NUMB = GS_IT_GEN-DELIV_NUMB
ITM_NUMBER = GS_IT_GEN-ITM_NUMBER BINARY SEARCH.

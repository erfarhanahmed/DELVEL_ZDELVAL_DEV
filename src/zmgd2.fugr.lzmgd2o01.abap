MODULE modify_screen OUTPUT.

  IF  sy-tcode cs '3'.

    LOOP AT SCREEN.

      IF screen-name = 'MARA-BOM'.
        SCREEN-INPUT = 0.
MODIFY SCREEN.
      ENDIF.



    ENDLOOP.

  ENDIF.


ENDMODULE.

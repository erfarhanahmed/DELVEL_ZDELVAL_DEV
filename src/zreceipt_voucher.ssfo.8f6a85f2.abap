
SELECT SINGLE BLDAT
FROM BKPF
INTO BLDAT
WHERE BUKRS = '7500'
AND BELNR = P_BELNR
AND GJAHR = P_GJAHR.

SELECT SINGLE kunnr
FROM BSEG
INTO KUNNR
WHERE BUKRS = '7500'
AND BELNR = P_BELNR
AND GJAHR = P_GJAHR
AND KOART = 'D'.

IF KUNNR IS NOT INITIAL.
SELECT SINGLE *
FROM KNA1
INTO LS_KNA1
WHERE KUNNR = KUNNR.
ENDIF.

SELECT SINGLE BEZEI
FROM T005U
INTO STATE1
WHERE SPRAS = SY-LANGU
AND LAND1 = LS_KNA1-LAND1
AND BLAND = LS_KNA1-REGIO.

CONCATENATE LS_KNA1-ORT01
            STATE1
       INTO ADDRESS1 SEPARATED BY SPACE.

GST1 = LS_KNA1-STCD3.

















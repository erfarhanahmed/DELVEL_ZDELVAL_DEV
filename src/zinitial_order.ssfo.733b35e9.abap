
*BREAK-POINT.

SELECT  VBELN KNUMV FROM vbak INTO CORRESPONDING FIELDS OF TABLE IT_VBAK
  WHERE vbeln = lv_vbeln.

  IF IT_VBAK  IS NOT INITIAL.
SELECT  KNUMV  KSCHL  KBETR
  FROM KONV
  INTO CORRESPONDING FIELDS OF TABLE IT_KONV
  FOR ALL ENTRIES IN IT_VBAK
  WHERE KNUMV = IT_VBAK-KNUMV
  AND   KSCHL = 'ZTE1'.
  ENDIF.

  LOOP AT IT_VBAK INTO WA_VBAK WHERE vbeln = lv_vbeln.
    WA_FINAL-KNUMV = WA_VBAK-KNUMV.

    READ TABLE IT_KONV INTO WA_KONV WITH KEY KNUMV = WA_VBAK-KNUMV.
*    WA_FINAL-KBETR = WA_KONV-KBETR.

    CLEAR : WA_KONV-KBETR.

  ENDLOOP.
Clear WA_FINAL-KBETR.

  LOOP AT IT_KONV INTO DATA(LS).
      WA_FINAL-KBETR = WA_FINAL-KBETR + LS-KBETR.
  ENDLOOP.





















*----------------------------------------------------------------------*
***INCLUDE LZFG_JSON_CONVERSIONF01.
*----------------------------------------------------------------------*
*&---------------------------------------------------------------------*
*&      Form  GET_DATA_ALL
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*      -->P_LT_RETMSG  text
*      -->P_VBELN  text
*      -->P_GJAHR  text
*----------------------------------------------------------------------*
FORM GET_DATA_ALL  TABLES LT_RETMSG STRUCTURE BAPIRET2
                          LT_DOCS STRUCTURE ZSTR_VBELN
                  USING VBELN TYPE VBELN
                        GJAHR TYPE GJAHR
                        LV_MODE TYPE FLAG
                        LV_UCOMM TYPE SY-UCOMM    .

  REFRESH LT_FINAL.
  DATA LC_VBELN TYPE VBELN.
  DATA : LV_DATE TYPE STRING.
  DATA: LV_LINES TYPE I.
  DATA : I_TEXT TYPE CHAR100,
         E_TEXT TYPE CHAR100.

  IF LT_DOCS[] IS NOT INITIAL.
    DESCRIBE TABLE LT_DOCS LINES LV_LINES.
  ENDIF.

  LC_VBELN = VBELN.




  "===============================================================================================
  " Data Fetch all
  "===============================================================================================

  IF LC_VBELN IS NOT INITIAL.
    SELECT
      VBELN FKART WAERK  KNUMV FKDAT GJAHR RFBSK ZTERM BUKRS XBLNR ZUONR BUPLA VKORG VTWEG LAND1
       FROM VBRK
               INTO TABLE LT_VBRK
               WHERE VBELN EQ LC_VBELN.

  ENDIF.

  IF LT_VBRK IS NOT INITIAL.
    DESCRIBE TABLE LT_VBRK LINES LV_DOCS.
    SELECT
      VBELN POSNR FKIMG VRKME NTGEW NETWR MATNR ARKTX PSTYV WERKS VGBEL "LGORT "lgort added by jyoti on 18.06.2024
       FROM VBRP
            INTO TABLE LT_VBRP
            FOR ALL ENTRIES IN LT_VBRK
            WHERE VBELN = LT_VBRK-VBELN.

    "----Eway details---------------------------------------------------------------------

    IF LT_VBRP IS NOT INITIAL.

      SELECT VBELN POSNR PARVW LIFNR
        FROM VBPA INTO TABLE LT_VBPA_EWAY
        FOR ALL ENTRIES IN LT_VBRP
        WHERE VBELN = LT_VBRP-VGBEL AND
              PARVW = 'LF'.

      IF LT_VBPA_EWAY IS NOT INITIAL.
        SELECT LIFNR NAME1 STCD3 FROM
        LFA1 INTO TABLE LT_LFA1_EWAY
         FOR ALL ENTRIES IN LT_VBPA_EWAY
          WHERE LIFNR = LT_VBPA_EWAY-LIFNR.
      ENDIF.

      SELECT VBELN,BOLNR FROM LIKP
        INTO TABLE @DATA(LT_LIKP_EWAY)
        FOR ALL ENTRIES IN @LT_VBRP
        WHERE VBELN = @LT_VBRP-VGBEL.


      WAIT UP TO 1 SECONDS.

      SELECT
        VBELN
        TRNS_MD
        TRANS_DOC
        DOC_DT
        TRANS_ID
        TRANS_NAME
        VEHICAL_NO
        VEHICAL_TYPE
        DISTANCE
        FROM ZEWAY_BILL INTO TABLE LT_ZEWAY_TAB
        FOR ALL ENTRIES IN LT_VBRK
        WHERE VBELN = LT_VBRK-VBELN.

    ENDIF.
*-----------------------------------------------------------------------------------------



    SELECT
      BUKRS BRANCH GSTIN
       FROM J_1BBRANCH
            INTO TABLE LT_J_1BBRANCH
            FOR ALL ENTRIES IN LT_VBRK
            WHERE BUKRS = LT_VBRK-BUKRS AND
                  BRANCH = LT_VBRK-BUPLA.

    SELECT * FROM T001
             INTO CORRESPONDING FIELDS OF TABLE LT_T001
             FOR ALL ENTRIES IN LT_VBRK
             WHERE BUKRS = LT_VBRK-BUKRS.

    SELECT
         BUKRS
         VKORG
         FKART
         BASE_KSCHL
         DISC_KSCHL
         OTHER_KSCHL
         TYPE
         CATEGORY
         EXPCAT
         FLAG
         FOC_FLAG
      FROM ZEINV_LINK INTO TABLE LT_ZEINV_LINK
      FOR ALL ENTRIES IN LT_VBRK
      WHERE
      BUKRS = LT_VBRK-BUKRS AND
      FKART = LT_VBRK-FKART AND
      VKORG = LT_VBRK-VKORG.


    SELECT ZTERM TEXT1 FROM T052U INTO TABLE LT_T052U
      FOR ALL ENTRIES IN LT_VBRK
      WHERE ZTERM = LT_VBRK-ZTERM.



    IF LT_VBRP IS NOT INITIAL.

      SELECT MATNR WERKS STEUC FROM MARC INTO TABLE LT_MARC
        FOR ALL ENTRIES IN LT_VBRP
        WHERE MATNR = LT_VBRP-MATNR AND
              WERKS = LT_VBRP-WERKS.

      SELECT VBELN VKORG VSTEL
        KUNNR
        KUNAG
        FROM LIKP
        INTO TABLE LT_LIKP
        FOR ALL ENTRIES IN LT_VBRP
        WHERE VBELN = LT_VBRP-VGBEL.


      SELECT
        WERKS NAME1  KUNNR LIFNR ADRNR
          FROM T001W
                INTO  TABLE LT_T001W
                FOR ALL ENTRIES IN LT_VBRP
                WHERE WERKS = LT_VBRP-WERKS.


      IF LT_T001W IS NOT INITIAL.
        SELECT
          ADDRNUMBER
          NAME1
          CITY1
          POST_CODE1
          STREET
          STR_SUPPL1
          STR_SUPPL2
          LOCATION
          COUNTRY
          REGION
          SORT1
          MC_CITY1
          TEL_NUMBER

           FROM ADRC
                 INTO CORRESPONDING FIELDS OF TABLE LT_ADRC
                 FOR ALL ENTRIES IN LT_T001W
                 WHERE ADDRNUMBER = LT_T001W-ADRNR.
      ENDIF.
    ENDIF.

    IF LT_ADRC IS NOT INITIAL.

      SELECT
        ZSTCODE
        ZSAPCODE
        ZSTDECR
        FROM ZSTATE_CODE
        INTO TABLE LT_ZSTATE_CODE
        FOR ALL ENTRIES IN LT_ADRC
        WHERE ZSAPCODE EQ LT_ADRC-REGION.

    ENDIF.


    IF LT_LIKP IS NOT INITIAL.
      SELECT
        KUNNR LAND1 NAME1 PSTLZ REGIO ADRNR STCD3
         FROM KNA1
               INTO TABLE LT_KNA1
               FOR ALL ENTRIES IN LT_LIKP
               WHERE KUNNR = LT_LIKP-KUNNR.


      SELECT VBELN POSNR PARVW KUNNR FROM VBPA
        INTO TABLE LT_VBPA
        FOR ALL ENTRIES IN LT_LIKP WHERE
        VBELN = LT_LIKP-VBELN AND PARVW = 'ZS'.

      IF LT_VBPA[] IS NOT INITIAL.
        SELECT KUNNR LOCCO FROM KNA1 INTO TABLE LT_KNA1_EXP
          FOR ALL ENTRIES IN LT_VBPA
          WHERE KUNNR = LT_VBPA-KUNNR.


        LOOP AT LT_VBPA INTO LS_VBPA.

          READ TABLE LT_KNA1_EXP INTO LS_KNA1_EXP WITH KEY KUNNR = LS_VBPA-KUNNR.
          IF SY-SUBRC EQ 0.
            LOOP AT LT_LIKP INTO LS_LIKP WHERE VBELN  = LS_VBPA-VBELN .
              LS_LIKP-KUNNR = LS_KNA1_EXP-KUNNR.
              MODIFY LT_LIKP FROM LS_LIKP TRANSPORTING KUNNR.
            ENDLOOP.
          ENDIF.
        ENDLOOP.
      ENDIF.
*         ENDIF.



      SELECT KUNNR ALAND TATYP TAXKD
      FROM KNVI INTO TABLE LT_KNVI_EXPWP
       FOR ALL ENTRIES IN LT_LIKP
      WHERE KUNNR = LT_LIKP-KUNAG AND TAXKD = '0' AND TATYP =  'JOIG'.

      SELECT KUNNR ALAND TATYP TAXKD
      FROM KNVI INTO TABLE LT_KNVI_DEXP
       FOR ALL ENTRIES IN LT_LIKP
      WHERE KUNNR = LT_LIKP-KUNAG AND TAXKD = '3' AND ( TATYP = 'JOCG'  OR TATYP =  'JOIG' OR TATYP = 'JOSG' ).

      DESCRIBE TABLE LT_KNVI_DEXP LINES LV_RECORS_D.




      SELECT KUNNR ALAND TATYP TAXKD
      FROM KNVI INTO TABLE LT_KNVI_SEZEXP
       FOR ALL ENTRIES IN LT_LIKP
      WHERE KUNNR = LT_LIKP-KUNAG AND TAXKD = '2' AND ( TATYP = 'JOCG'  OR TATYP =  'JOIG' OR TATYP = 'JOSG' ).

      DESCRIBE TABLE LT_KNVI_SEZEXP LINES LV_RECORS_S.

    ENDIF.

  ELSE.

    LS_RETMSG-ID = 'E'.
    LS_RETMSG-MESSAGE = 'No Data Available'.
    LV_ERROR = 'X'.
    APPEND LS_RETMSG TO LT_RETMSG.
    CLEAR LS_RETMSG.
    EXIT.
    LEAVE LIST-PROCESSING.

  ENDIF.

*  PERFORM process_data CHANGING lt_final.


  "===============================================================================================
  " Process Data
  "===============================================================================================

  "--New Code-----------------------------------------
*BREAK PRIMUS.
  LOOP AT LT_VBRK INTO LS_VBRK.


    IF LS_VBRK-RFBSK = 'C'.  "--Check is posting is completed or not 'C' = posting Done.
      READ TABLE LT_VBRP INTO LS_VBRP WITH KEY VBELN = LS_VBRK-VBELN.
      IF SY-SUBRC IS INITIAL.
        READ TABLE LT_LIKP INTO LS_LIKP WITH KEY  VBELN = LS_VBRP-VGBEL.
        IF SY-SUBRC IS INITIAL.

          IF LS_VBRP-WERKS EQ  LS_LIKP-VSTEL AND LS_LIKP-KUNAG EQ LS_LIKP-KUNNR.
            LV_TYP = LC_TYP_REG.                            "'REG'.
          ELSEIF LS_LIKP-VSTEL NE LS_VBRP-WERKS AND LS_LIKP-KUNAG EQ LS_LIKP-KUNNR.
            LV_TYP  = LC_TYP_DIS.
          ELSEIF LS_LIKP-KUNAG NE LS_LIKP-KUNNR.
            LV_TYP  = LC_TYP_SHP.
          ELSEIF LS_LIKP-VSTEL NE LS_VBRP-WERKS AND LS_LIKP-KUNAG NE LS_LIKP-KUNNR.
            LV_TYP  = LC_TYP_CMB.
          ENDIF.
        ELSE.
          IF LS_VBRK-FKART = 'ZSER' OR LS_VBRK-FKART = 'ZESS' OR LS_VBRK-FKART = 'ZLIS' .

            LV_TYP  = LC_TYP_SER.

          ENDIF.
        ENDIF.
      ENDIF.
      "--Addr Details for REG  DIS SHP CMB

      CALL FUNCTION 'ZEINV_GET_ADRC_DATA'
        EXPORTING
          I_VBRP     = LS_VBRP
          I_LIKP     = LS_LIKP
          I_INVTYP   = LV_TYP
        IMPORTING
          E_SEL_ADDR = LS_SEL_ADDR
          E_DIS_ADDR = LS_DIS_ADDR
          E_BUY_ADDR = LS_BUY_ADDR
          E_SHP_ADDR = LS_SHP_ADDR.

************************************************************************************
      "--INR Details
************************************************************************************
      LS_FINAL-VERSION = LC_VERSION.            "'1.0'.
      LS_FINAL-IRN = ''.
************************************************************************************
      "--TranDtls (Transaction Details)---------
************************************************************************************

      READ TABLE LT_ZEINV_LINK INTO LS_ZEINV_LINK WITH KEY BUKRS = LS_VBRK-BUKRS  FKART = LS_VBRK-FKART VKORG = LS_VBRK-VKORG.
      IF SY-SUBRC IS INITIAL .
        LS_FINAL-TRANDTLS-TAXSCH = LC_TAXSCH.  "'GST'.
        LS_FINAL-TRANDTLS-REGREV = LC_REGREV.               "Y/N
        LS_FINAL-TRANDTLS-ECMGSTIN = LC_NULL.

        IF LS_ZEINV_LINK-CATEGORY IS NOT INITIAL. "'B2B'..
          LS_FINAL-TRANDTLS-SUPTYP = LS_ZEINV_LINK-CATEGORY. "'B2B'.
        ELSE.
          READ TABLE LT_KNVI_DEXP INTO LS_KNVI_DEXP WITH KEY KUNNR = LS_LIKP-KUNAG.
          IF SY-SUBRC EQ 0 AND LV_RECORS_D EQ '3' AND LS_BUY_ADDR-COUNTRY EQ 'IN'.
            LS_FINAL-TRANDTLS-SUPTYP = 'DEXP'.
          ENDIF.

          READ TABLE LT_KNVI_EXPWP INTO LS_KNVI_EXPWP WITH KEY KUNNR = LS_LIKP-KUNAG.
          IF SY-SUBRC EQ 0 AND LS_BUY_ADDR-COUNTRY NE 'IN'.

            SELECT SINGLE  KNUMV KSCHL KSTAT FROM PRCD_ELEMENTS  INTO LS_KONV_EXP
*            SELECT SINGLE  knumv kschl kstat FROM konv INTO ls_konv_exp  " commented by amit
            WHERE KNUMV = LS_VBRK-KNUMV AND KSCHL = LS_ZEINV_LINK-BASE_KSCHL.
            IF SY-SUBRC EQ 0.
              IF LS_KONV_EXP-KSTAT = 'X'.
                LS_FINAL-TRANDTLS-SUPTYP = 'EXPWOP'.
              ELSE.
                LS_FINAL-TRANDTLS-SUPTYP = 'EXPWP'.
              ENDIF.
            ENDIF.
          ENDIF.


          READ TABLE LT_KNVI_SEZEXP INTO LS_KNVI_SEZEXP WITH KEY KUNNR = LS_LIKP-KUNAG.
          IF SY-SUBRC EQ 0 AND LV_RECORS_S EQ '3'.
            SELECT SINGLE  KNUMV KSCHL KSTAT FROM PRCD_ELEMENTS INTO LS_KONV_EXP
*            SELECT SINGLE  knumv kschl kstat FROM konv INTO ls_konv_exp  "commented by amit
            WHERE KNUMV = LS_VBRK-KNUMV AND KSCHL = LS_ZEINV_LINK-BASE_KSCHL.
            IF SY-SUBRC EQ 0.
              IF LS_KONV_EXP-KSTAT = 'X'.
                LS_FINAL-TRANDTLS-SUPTYP = 'SEZWOP'.
              ELSE.
                LS_FINAL-TRANDTLS-SUPTYP = 'SEZWP'.
              ENDIF.
            ENDIF.
          ENDIF.


        ENDIF.

        IF LS_VBRK-FKART = 'ZSER' AND LS_VBRK-VTWEG = '20'.
          LS_FINAL-TRANDTLS-SUPTYP = 'SEZWOP'.
        ELSEIF LS_VBRK-FKART = 'ZFRS' AND LS_VBRK-VTWEG = '20'.
          LS_FINAL-TRANDTLS-SUPTYP = 'SEZWOP'.
        ELSEIF LS_VBRK-FKART = 'ZFRS' AND LS_VBRK-VTWEG = '30'.  "Added By Nilay On 15.06.2023
          LS_FINAL-TRANDTLS-SUPTYP = 'EXPWOP'.
        ENDIF.

************        Avinash Bhagat
        IF LS_VBRK-FKART = 'ZFOC' AND LS_VBRK-WAERK NE 'INR' .
          LS_FINAL-TRANDTLS-SUPTYP = 'EXPWOP'.
        ENDIF.
***        end Avinash Bhagat

        IF LS_FINAL-TRANDTLS-ECMGSTIN IS NOT INITIAL.
          LS_UPDATE-TRANDTLS = 'X'.
        ENDIF.
************************************************************************************
        "--DocDtls (Document Details)--------------
************************************************************************************

        CONCATENATE LS_VBRK-FKDAT+6(02) '/' LS_VBRK-FKDAT+4(02) '/' LS_VBRK-FKDAT(04)  INTO LV_DATE.
*       CONCATENATE sy-datum+6(02) '/' sy-datum+4(02) '/' sy-datum(04)  INTO lv_date.                        " ??????????????????????????????

        LS_FINAL-ZDOCDTLS-ZTYP = LS_ZEINV_LINK-TYPE.

        SHIFT LS_VBRK-XBLNR LEFT DELETING LEADING '0'.
        LS_FINAL-ZDOCDTLS-ZNO  = LS_VBRK-XBLNR.
        LS_FINAL-ZDOCDTLS-ZDT  = LV_DATE.
      ELSE.
        MESSAGE E000 WITH LS_VBRK-BUKRS LS_VBRK-FKART LS_VBRK-VKORG. "'Please maintain zirn_link table '   TYPE 'E' DISPLAY LIKE 'E'.
      ENDIF.
************************************************************************************
      "--SellerDtls (Seller Details)------------------
************************************************************************************
      READ TABLE LT_T001 INTO LS_T001 WITH KEY BUKRS = LS_VBRK-BUKRS.
      IF SY-SUBRC IS INITIAL.
        LS_FINAL-SELLERDTLS-LGLNM  = LS_T001-BUTXT.
        LS_FINAL-SELLERDTLS-TRDNM  = LS_T001-BUTXT.
      ENDIF.

      READ TABLE LT_J_1BBRANCH INTO LS_J_1BBRANCH WITH KEY BUKRS = LS_VBRK-BUKRS BRANCH = LS_VBRK-BUPLA.
      IF SY-SUBRC IS INITIAL.
        IF LV_MODE = 'X'.
          LS_FINAL-SELLERDTLS-GSTIN  =  LS_J_1BBRANCH-GSTIN."'27AACCD2898L1Z4'."'24AAAPI3182M002'. "ls_t001-gstin
        ELSE.
          LS_FINAL-SELLERDTLS-GSTIN  =  LS_J_1BBRANCH-GSTIN." '24AAAPI3182M002'. "ls_t001-gstin
        ENDIF.

      ELSE.
        LS_FINAL-SELLERDTLS-GSTIN  = 'URP'.
      ENDIF.
      LS_FINAL-SELLERDTLS-ADDR1  =  LS_SEL_ADDR-STR_SUPPL1.

      IF LS_SEL_ADDR-STR_SUPPL2 IS INITIAL.
        LS_FINAL-SELLERDTLS-ADDR2  = LC_NULL.
      ELSE.
        LS_FINAL-SELLERDTLS-ADDR2  = LS_SEL_ADDR-STR_SUPPL2.
      ENDIF.

      LS_FINAL-SELLERDTLS-ZLOC    = LS_SEL_ADDR-MC_CITY1.
      LS_FINAL-SELLERDTLS-ZPIN    = LS_SEL_ADDR-POST_CODE1.
      IF LV_MODE = 'X'.
        LS_FINAL-SELLERDTLS-ZSTATE  = LS_SEL_ADDR-REGION."'MAHARASHTRA'.
      ELSE.
        LS_FINAL-SELLERDTLS-ZSTATE  = LS_SEL_ADDR-REGION.
      ENDIF.

      LS_FINAL-SELLERDTLS-ZEM     = LC_NULL.
      IF LS_SEL_ADDR-TEL_NUMBER IS NOT INITIAL.
        LS_FINAL-SELLERDTLS-ZPH     = LC_NULL."ls_sel_addr-tel_number.

      ELSE.
        LS_FINAL-SELLERDTLS-ZPH = LC_NULL.
      ENDIF.


      "Code to remove Special Char.
      REPLACE ALL OCCURRENCES OF ',' IN LS_FINAL-SELLERDTLS-LGLNM WITH CL_ABAP_CHAR_UTILITIES=>HORIZONTAL_TAB.
      REPLACE ALL OCCURRENCES OF '&' IN LS_FINAL-SELLERDTLS-LGLNM WITH CL_ABAP_CHAR_UTILITIES=>HORIZONTAL_TAB.
      REPLACE ALL OCCURRENCES OF '/' IN LS_FINAL-SELLERDTLS-LGLNM WITH CL_ABAP_CHAR_UTILITIES=>HORIZONTAL_TAB.
      MOVE LS_FINAL-SELLERDTLS-LGLNM TO I_TEXT.
      PERFORM ES_REMOVE_SPECIAL_CHARACTER USING I_TEXT CHANGING E_TEXT.
      MOVE E_TEXT TO LS_FINAL-SELLERDTLS-LGLNM.
      CLEAR : E_TEXT, I_TEXT.
      "end of  remove speccial char.


      REPLACE ALL OCCURRENCES OF ',' IN LS_FINAL-SELLERDTLS-TRDNM WITH CL_ABAP_CHAR_UTILITIES=>HORIZONTAL_TAB.
      REPLACE ALL OCCURRENCES OF ',' IN LS_FINAL-SELLERDTLS-TRDNM WITH CL_ABAP_CHAR_UTILITIES=>HORIZONTAL_TAB.
      REPLACE ALL OCCURRENCES OF ',' IN LS_FINAL-SELLERDTLS-TRDNM WITH CL_ABAP_CHAR_UTILITIES=>HORIZONTAL_TAB.
      MOVE LS_FINAL-SELLERDTLS-TRDNM TO I_TEXT.
      PERFORM ES_REMOVE_SPECIAL_CHARACTER USING I_TEXT CHANGING E_TEXT.
      MOVE E_TEXT TO LS_FINAL-SELLERDTLS-TRDNM.
      CLEAR : E_TEXT, I_TEXT.



      REPLACE ALL OCCURRENCES OF ',' IN LS_FINAL-SELLERDTLS-ADDR1 WITH CL_ABAP_CHAR_UTILITIES=>HORIZONTAL_TAB.
      REPLACE ALL OCCURRENCES OF '&' IN LS_FINAL-SELLERDTLS-ADDR1 WITH CL_ABAP_CHAR_UTILITIES=>HORIZONTAL_TAB.
      REPLACE ALL OCCURRENCES OF '/' IN LS_FINAL-SELLERDTLS-ADDR1 WITH CL_ABAP_CHAR_UTILITIES=>HORIZONTAL_TAB.
      MOVE LS_FINAL-SELLERDTLS-ADDR1 TO I_TEXT.
      PERFORM ES_REMOVE_SPECIAL_CHARACTER USING I_TEXT CHANGING E_TEXT.
      MOVE E_TEXT TO LS_FINAL-SELLERDTLS-ADDR1.
      CLEAR : E_TEXT, I_TEXT.




      REPLACE ALL OCCURRENCES OF ',' IN LS_FINAL-SELLERDTLS-ADDR2 WITH CL_ABAP_CHAR_UTILITIES=>HORIZONTAL_TAB.
      REPLACE ALL OCCURRENCES OF '&' IN LS_FINAL-SELLERDTLS-ADDR2 WITH CL_ABAP_CHAR_UTILITIES=>HORIZONTAL_TAB.
      REPLACE ALL OCCURRENCES OF '/' IN LS_FINAL-SELLERDTLS-ADDR2 WITH CL_ABAP_CHAR_UTILITIES=>HORIZONTAL_TAB.
      MOVE LS_FINAL-SELLERDTLS-ADDR2 TO I_TEXT.
      PERFORM ES_REMOVE_SPECIAL_CHARACTER USING I_TEXT CHANGING E_TEXT.
      MOVE E_TEXT TO LS_FINAL-SELLERDTLS-ADDR2.
      CLEAR : E_TEXT, I_TEXT.


      REPLACE ALL OCCURRENCES OF ',' IN LS_FINAL-SELLERDTLS-ZLOC WITH CL_ABAP_CHAR_UTILITIES=>HORIZONTAL_TAB.
      REPLACE ALL OCCURRENCES OF '&' IN LS_FINAL-SELLERDTLS-ZLOC WITH CL_ABAP_CHAR_UTILITIES=>HORIZONTAL_TAB.
      REPLACE ALL OCCURRENCES OF '/' IN LS_FINAL-SELLERDTLS-ZLOC WITH CL_ABAP_CHAR_UTILITIES=>HORIZONTAL_TAB.
      MOVE LS_FINAL-SELLERDTLS-ZLOC TO I_TEXT.
      PERFORM ES_REMOVE_SPECIAL_CHARACTER USING I_TEXT CHANGING E_TEXT.
      MOVE E_TEXT TO LS_FINAL-SELLERDTLS-ZLOC.
      CLEAR : E_TEXT, I_TEXT.


      REPLACE ALL OCCURRENCES OF ',' IN LS_FINAL-SELLERDTLS-ZSTATE  WITH CL_ABAP_CHAR_UTILITIES=>HORIZONTAL_TAB.
      REPLACE ALL OCCURRENCES OF '&' IN LS_FINAL-SELLERDTLS-ZSTATE  WITH CL_ABAP_CHAR_UTILITIES=>HORIZONTAL_TAB.
      REPLACE ALL OCCURRENCES OF '/' IN LS_FINAL-SELLERDTLS-ZSTATE  WITH CL_ABAP_CHAR_UTILITIES=>HORIZONTAL_TAB.
      MOVE LS_FINAL-SELLERDTLS-ZSTATE TO I_TEXT.
      PERFORM ES_REMOVE_SPECIAL_CHARACTER USING I_TEXT CHANGING E_TEXT.
      MOVE E_TEXT TO LS_FINAL-SELLERDTLS-ZSTATE.
      CLEAR : E_TEXT, I_TEXT.






************************************************************************************
      "--BuyerDtls (Buyers Details)------
************************************************************************************

*      IF lv_mode = 'X'.
*        ls_final-buyerdtls-gstin   = 'URP'."'23AAACJ3929N1ZE'.
*      ELSE.
*
*      ENDIF.
*
*      IF ls_final-buyerdtls-gstin IS INITIAL.
*        IF ls_final-trandtls-suptyp = 'EXPWP' OR ls_final-trandtls-suptyp = 'EXPWOP' OR ls_final-trandtls-suptyp = 'DEXP' .
*          ls_final-buyerdtls-gstin   = 'URP'.                                       "?????????????????????
*        ELSE.
*          ls_final-buyerdtls-gstin   = ls_buy_addr-gstin. "
*        ENDIF.
*
*      ENDIF.

      IF LS_BUY_ADDR-COUNTRY  NE 'IN'.
        LS_FINAL-BUYERDTLS-GSTIN   = 'URP'.
      ELSE.
        LS_FINAL-BUYERDTLS-GSTIN   = LS_BUY_ADDR-GSTIN. "
      ENDIF.
      LS_FINAL-BUYERDTLS-LGLNM   = LS_BUY_ADDR-NAME1.
      LS_FINAL-BUYERDTLS-TRDNM   = LS_BUY_ADDR-NAME1.

      LS_FINAL-BUYERDTLS-ZPOS     = LS_BUY_ADDR-REGION.
      IF LS_BUY_ADDR-COUNTRY  NE 'IN'.
        LS_FINAL-BUYERDTLS-ZPOS = '96'.
      ENDIF.
      LS_FINAL-BUYERDTLS-ADDR1   = LS_BUY_ADDR-STREET. "ls_buy_addr-str_suppl1.temp>>>>>>>>>>>>>>>>>>>>>>>>>>

      IF LS_BUY_ADDR-STR_SUPPL2 IS INITIAL.
        LS_FINAL-BUYERDTLS-ADDR2   = LC_NULL.
      ELSE.
        LS_FINAL-BUYERDTLS-ADDR2   = LS_BUY_ADDR-STR_SUPPL2.
      ENDIF.

      LS_FINAL-BUYERDTLS-ZLOC     = LS_BUY_ADDR-MC_CITY1.

      IF LV_MODE = 'X'.
        LS_FINAL-BUYERDTLS-ZSTATE   = LS_BUY_ADDR-REGION.
      ELSE.
        LS_FINAL-BUYERDTLS-ZSTATE   = LS_BUY_ADDR-REGION.
      ENDIF.
      IF LS_BUY_ADDR-COUNTRY  NE 'IN'.
        LS_FINAL-BUYERDTLS-ZSTATE   = '96'.   "State Code Shuold be 96 for export case
        LS_FINAL-BUYERDTLS-ZPIN      = '999999'.
      ELSE.

        LS_FINAL-BUYERDTLS-ZPIN      = LS_BUY_ADDR-POST_CODE1.
      ENDIF.


      LS_FINAL-BUYERDTLS-ZPH      = LC_NULL."ls_buy_addr-tel_number.

      IF LS_BUY_ADDR-TEL_NUMBER IS INITIAL.
        LS_FINAL-BUYERDTLS-ZPH = LC_NULL.
      ENDIF.

      LS_FINAL-BUYERDTLS-ZEM      = LC_NULL.

      "Code to remove Special Char----------------------------------------------------------------------------

      REPLACE ALL OCCURRENCES OF ',' IN LS_FINAL-BUYERDTLS-LGLNM    WITH CL_ABAP_CHAR_UTILITIES=>HORIZONTAL_TAB.
      REPLACE ALL OCCURRENCES OF '&' IN LS_FINAL-BUYERDTLS-LGLNM    WITH CL_ABAP_CHAR_UTILITIES=>HORIZONTAL_TAB.

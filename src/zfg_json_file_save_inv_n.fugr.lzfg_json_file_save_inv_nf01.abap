*&      Form  GET_DATA_CANCEL
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*      -->P_LT_RETMSG  text
*      -->P_VBELN  text
*      -->P_GJAHR  text
*----------------------------------------------------------------------*
FORM GET_DATA_CANCEL  TABLES   LT_RETMSG STRUCTURE BAPIRET2
                                 "Insert a correct name for <...>
                      USING    VBELN
                               GJAHR
                               LV_UCOMM TYPE SY-UCOMM.


  DATA LC_VBELN TYPE VBELN.
  LC_VBELN = VBELN.

  DATA : LS_ZEINV_CANCEL    TYPE ZEINV_RES.
  DATA : LS_ZEWAY_BILL      TYPE ZEWAY_BILL.
  DATA : LS_J_1IG_INVREFNUM TYPE J_1IG_INVREFNUM .

  CALL FUNCTION 'CONVERSION_EXIT_ALPHA_INPUT'
    EXPORTING
      INPUT  = LC_VBELN
    IMPORTING
      OUTPUT = LC_VBELN.





  IF LV_UCOMM = '&CAN'.

    SELECT SINGLE * FROM ZEINV_RES INTO LS_ZEINV_CANCEL
    WHERE VBELN = LC_VBELN.
    IF SY-SUBRC IS INITIAL AND LS_ZEINV_CANCEL-ZZIRN_NO IS NOT INITIAL.
      LS_FINAL_CANCEL-IRN = LS_ZEINV_CANCEL-ZZIRN_NO.
      LS_FINAL_CANCEL-CNLRSN = LS_ZEINV_CANCEL-ZZCAN_RSN.
      LS_FINAL_CANCEL-CNLREM = LS_ZEINV_CANCEL-ZZCAN_REASON.
    ELSE.
      SELECT SINGLE * FROM J_1IG_INVREFNUM INTO LS_J_1IG_INVREFNUM
        WHERE DOCNO = LC_VBELN.
      IF SY-SUBRC IS INITIAL.
        SELECT SINGLE * FROM ZEINV_RES INTO LS_ZEINV_CANCEL
        WHERE VBELN = LC_VBELN.

        LS_FINAL_CANCEL-IRN = LS_J_1IG_INVREFNUM-IRN.
        LS_FINAL_CANCEL-CNLRSN = LS_ZEINV_CANCEL-ZZCAN_RSN.
        LS_FINAL_CANCEL-CNLREM = LS_ZEINV_CANCEL-ZZCAN_REASON.
      ENDIF.
    ENDIF.

  ELSEIF LV_UCOMM = '&CANEWAY'.
    SELECT SINGLE * FROM ZEINV_RES INTO LS_ZEINV_CANCEL
     WHERE VBELN = LC_VBELN.

    IF SY-SUBRC IS INITIAL.

      SELECT SINGLE * FROM ZEWAY_BILL INTO LS_ZEWAY_BILL WHERE
          VBELN = LC_VBELN.
      IF SY-SUBRC IS INITIAL.
        LS_FINAL_CANCEL_EWAY-EWBNO         = LS_ZEINV_CANCEL-ZZEWAYBILL_NO.
        LS_FINAL_CANCEL_EWAY-CANCELRSNCODE = LS_ZEWAY_BILL-REASONCODE.
        LS_FINAL_CANCEL_EWAY-CANCELRMRK    = LS_ZEWAY_BILL-REASON.
      ENDIF.
    ENDIF.
  ENDIF.
  CLEAR : LS_ZEINV_CANCEL,LS_ZEWAY_BILL.

ENDFORM.

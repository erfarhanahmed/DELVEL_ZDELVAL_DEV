        MOVE LS_ITEMLIST-PRDDESC TO I_TEXT.
        PERFORM ES_REMOVE_SPECIAL_CHARACTER USING I_TEXT CHANGING E_TEXT.
        MOVE E_TEXT TO LS_ITEMLIST-PRDDESC.
        CLEAR : E_TEXT, I_TEXT.


        READ TABLE LT_MARC INTO LS_MARC WITH KEY MATNR = LS_VBRP-MATNR WERKS = LS_VBRP-WERKS.
        IF SY-SUBRC IS INITIAL.
*          ls_itemlist-hsncd                =   ls_marc-steuc(06). "Changed by Nilay B. on 15.12.2023
          LS_ITEMLIST-HSNCD                =   LS_MARC-STEUC(08). "Changed by jyoti on 04.12.2024
          "'23099010'."   ??????????????????????????????????????????????????


          IF LS_MARC-STEUC+0(2) = '99'.
            LS_ITEMLIST-ISSERVC  = 'Y'.
          ELSE.
            LS_ITEMLIST-ISSERVC              =  'N' .
          ENDIF.

        ENDIF.
        LS_ITEMLIST-BARCDE               =   LC_NULL.
        LS_ITEMLIST-QNTY                  =   LS_VBRP-FKIMG.


        READ TABLE LT_ZEINV_LINK INTO LS_ZEINV_LINK WITH KEY BUKRS = LS_VBRK-BUKRS  FKART = LS_VBRK-FKART VKORG = LS_VBRK-VKORG FOC_FLAG = 'X' .
        IF SY-SUBRC IS INITIAL.
          LS_ITEMLIST-FREEQTY              =   LS_VBRP-FKIMG.
        ELSE.
          LS_ITEMLIST-FREEQTY              =   '0'.
        ENDIF.

        "Convert  SAP Unit to IRP Unit.
        CALL FUNCTION 'ZEINV_UNIT_CONVERT'
          EXPORTING
            VRKME = LS_VBRP-VRKME
          IMPORTING
            UNIT  = LS_ITEMLIST-UNITS.
        " Get unitprice and totamt

        IF LS_VBRK-WAERK EQ 'INR'.


          SELECT SINGLE KBETR KWERT
                              FROM PRCD_ELEMENTS INTO ( LS_ITEMLIST-UNITPRICE, LS_ITEMLIST-TOTAMT  )
*                              FROM konv INTO ( ls_itemlist-unitprice, ls_itemlist-totamt  )  "commented by Amit
                              WHERE KNUMV = LS_VBRK-KNUMV AND
                                    KPOSN = LS_VBRP-POSNR AND
                                    ( KSCHL = LS_ZEINV_LINK-BASE_KSCHL )."'ZPRO' ).

        ELSEIF LS_VBRK-WAERK NE 'INR'.

          SELECT SINGLE KBETR KWERT
                              FROM PRCD_ELEMENTS INTO ( LS_ITEMLIST-UNITPRICE, LS_ITEMLIST-TOTAMT )
*                              FROM konv INTO ( ls_itemlist-unitprice, ls_itemlist-totamt )  "commenetd by  Amit
                              WHERE KNUMV = LS_VBRK-KNUMV AND
                                    KPOSN = LS_VBRP-POSNR AND
                                    ( KSCHL = LS_ZEINV_LINK-BASE_KSCHL )."'ZPRO' ).

          SELECT SINGLE KKURS
                              FROM PRCD_ELEMENTS INTO LS_KKURS
*                              FROM konv INTO ls_kkurs    "COMMENTED BY AMIT
                              WHERE KNUMV = LS_VBRK-KNUMV AND
                                    KPOSN = LS_VBRP-POSNR AND
                                    ( KSCHL = 'VPRS' ).


          LS_ITEMLIST-UNITPRICE = LS_ITEMLIST-UNITPRICE * LS_KKURS.
          LS_ITEMLIST-TOTAMT = LS_ITEMLIST-TOTAMT * LS_KKURS.

        ENDIF.

        "------------Other Condition------------
        SELECT  KBETR KWERT KSCHL FROM PRCD_ELEMENTS
*        SELECT  kbetr kwert kschl FROM konv  "COMMENTED BY AMIT
                    INTO CORRESPONDING FIELDS OF TABLE LT_KONV_T
                    FOR ALL ENTRIES IN LT_ZEINV_LINK
                    WHERE KNUMV = LS_VBRK-KNUMV AND
                          KPOSN = LS_VBRP-POSNR AND
                          ( KSCHL = LT_ZEINV_LINK-OTHER_KSCHL ).
        LOOP AT LT_KONV_T.
          LS_ITEMLIST-OTHCHRG             =  LS_ITEMLIST-OTHCHRG + ( LT_KONV_T-KWERT * -1 ).
        ENDLOOP.
        IF LS_ITEMLIST-OTHCHRG LT 0.
          LS_ITEMLIST-OTHCHRG  = LS_ITEMLIST-OTHCHRG * -1.
        ENDIF.
*        ls_itemlist-assamt = ls_itemlist-assamt." + ls_itemlist-othchrg." . ???Commented (other charge added in totamt )
        REFRESH LT_KONV_T.
        BREAK PRIMUS.
        IF LS_VBRK-WAERK NE 'INR'.
          LS_ITEMLIST-OTHCHRG = LS_ITEMLIST-OTHCHRG * LS_KKURS.
        ENDIF.


        "code added to sum tot amt and other charge.
        LS_ITEMLIST-TOTAMT = LS_ITEMLIST-TOTAMT + LS_ITEMLIST-OTHCHRG.
        "End of add.



        "------------Discount Condition------------

        SELECT  KBETR KWERT KSCHL FROM PRCD_ELEMENTS
*        SELECT  kbetr kwert kschl FROM konv    "COMMENTED BY AMIT
                    INTO CORRESPONDING FIELDS OF TABLE LT_KONV_T
                    FOR ALL ENTRIES IN LT_ZEINV_LINK
                    WHERE KNUMV   = LS_VBRK-KNUMV AND
                          KPOSN   = LS_VBRP-POSNR AND
                          ( KSCHL = LT_ZEINV_LINK-DISC_KSCHL ).
        LOOP AT LT_KONV_T.
          LS_ITEMLIST-DISCOUNT    =  LS_ITEMLIST-DISCOUNT + ( LT_KONV_T-KWERT * -1 ).
        ENDLOOP.
        REFRESH LT_KONV_T.

        LS_ITEMLIST-PRETAXVAL     ='0.00'.
        LS_ITEMLIST-ASSAMT        = LS_ITEMLIST-TOTAMT - LS_ITEMLIST-DISCOUNT.
        IF LS_ITEMLIST-ASSAMT LT 0.
          LS_ITEMLIST-ASSAMT       = LS_ITEMLIST-ASSAMT * -1.
        ENDIF.


        "------------GST Condition------------

        SELECT  KBETR KWERT KSCHL KKURS FROM PRCD_ELEMENTS
*        SELECT  kbetr kwert kschl kkurs FROM konv  "COMMENTED BY AMIT
                            INTO CORRESPONDING FIELDS OF TABLE LT_KONV_T
                            WHERE KNUMV = LS_VBRK-KNUMV AND
                                  KPOSN = LS_VBRP-POSNR AND
                                   ( KSCHL = 'JOCG' OR KSCHL = 'JOSG' OR KSCHL = 'JOIG')
                                  AND KSTAT NE 'X'.

        LOOP AT LT_KONV_T.
          IF LT_KONV_T-KSCHL    = 'JOIG'.
            IF  LT_KONV_T-KBETR NE 0.
              LS_ITEMLIST-GSTRT   = LT_KONV_T-KBETR." / 10.
              IF LS_VBRK-WAERK EQ 'INR'.
                LS_ITEMLIST-IGSTAMT = LT_KONV_T-KWERT.
              ELSEIF LS_VBRK-WAERK NE 'INR'.
                LS_ITEMLIST-IGSTAMT = LT_KONV_T-KWERT * LS_KKURS.
*                lv_roundoff_amt     = ( ls_itemlist-assamt * ls_itemlist-gstrt ) / 100 .
*                lv_roundoff         = ls_itemlist-igstamt - lv_roundoff_amt.
              ENDIF.
            ENDIF.

          ELSEIF LT_KONV_T-KSCHL = 'JOCG'.
            IF LT_KONV_T-KBETR NE 0.
              LS_ITEMLIST-GSTRT    =  LS_ITEMLIST-GSTRT + LT_KONV_T-KBETR." / 10.
              LS_ITEMLIST-CGSTAMT  =  LT_KONV_T-KWERT.
            ENDIF.
          ELSEIF LT_KONV_T-KSCHL = 'JOSG'.
            IF LT_KONV_T-KBETR NE 0.
              LS_ITEMLIST-GSTRT    =  LS_ITEMLIST-GSTRT + LT_KONV_T-KBETR." / 10.
              LS_ITEMLIST-SGSTAMT  = LT_KONV_T-KWERT.
            ENDIF.
          ENDIF.


        ENDLOOP.


        REFRESH LT_KONV_T.

        "------------CES Condition------------

        SELECT  KBETR KWERT KSCHL FROM PRCD_ELEMENTS
*        SELECT  kbetr kwert kschl FROM konv   "COMMENTED BY AMIT
                            INTO CORRESPONDING FIELDS OF TABLE LT_KONV_T
                            FOR ALL ENTRIES IN LT_ZEINV_LINK
                            WHERE KNUMV = LS_VBRK-KNUMV AND
                                  KPOSN = LS_VBRP-POSNR AND

                                  ( KSCHL = LT_ZEINV_LINK-OTHER_KSCHL ).
        LOOP AT LT_KONV_T.
          IF LT_KONV_T-KSCHL        = 'CES'.
            LS_ITEMLIST-ZCESRT      = LT_KONV_T-KBETR / 10.
            LS_ITEMLIST-ZCESAMT     = LT_KONV_T-KWERT.
          ELSEIF LT_KONV_T-KSCHL = 'statece'.
            LS_ITEMLIST-STATECESRT  = LT_KONV_T-KBETR / 10.
            LS_ITEMLIST-STATECESAMT = LT_KONV_T-KWERT.
          ENDIF.
        ENDLOOP.

        CLEAR : LS_ITEMLIST-OTHCHRG.
        "-------------------------JTC1 condition-------------------------
        SELECT  KBETR KWERT KSCHL FROM PRCD_ELEMENTS
*        SELECT  kbetr kwert kschl FROM konv  "COMMENETED BY AMIT
                    INTO CORRESPONDING FIELDS OF TABLE LT_KONV_T
*                    FOR ALL ENTRIES IN lt_zeinv_link
                    WHERE KNUMV = LS_VBRK-KNUMV AND
                          KPOSN = LS_VBRP-POSNR AND
                          ( KSCHL = 'JTC1' OR KSCHL = 'ZTCS' ).
        LOOP AT LT_KONV_T.
          LS_ITEMLIST-OTHCHRG  =  LT_KONV_T-KWERT.
        ENDLOOP.



*
*          CLEAR lt_konv_t.
        LS_ITEMLIST-ZCESRT               = '0.00'.
        LS_ITEMLIST-ZCESAMT              = '0.00'.
        LS_ITEMLIST-ZCESNONADVLAMT       = '0.00'.
        LS_ITEMLIST-STATECESRT           = '0.00'.
        LS_ITEMLIST-STATECESAMT          = '0.00'.
        LS_ITEMLIST-STATECESNONADVLAMT   = '0.00'.

        IF LS_ITEMLIST-GSTRT IS INITIAL.
          LS_ITEMLIST-GSTRT = '0.00'.
        ENDIF.

        LS_ITEMLIST-TOTITEMVAL    =  LS_ITEMLIST-ASSAMT + LS_ITEMLIST-IGSTAMT + LS_ITEMLIST-SGSTAMT + LS_ITEMLIST-CGSTAMT +
                                     LS_ITEMLIST-ZCESAMT + LS_ITEMLIST-ZCESNONADVLAMT + LS_ITEMLIST-STATECESAMT + LS_ITEMLIST-STATECESNONADVLAMT +
                                     LS_ITEMLIST-OTHCHRG .
        LS_ITEMLIST-ORDLINEREF    =  '0.00'.
        LS_ITEMLIST-ORGCNTRY      =  'IN'.
        LS_ITEMLIST-PRDSLNO       =  LC_NULL.
************************************************************
        "--bchdtl (Batch Details)------------------
***********************************************************
        LS_ITEMLIST-BCHDTLS-ZNM          = ''.
        LS_ITEMLIST-BCHDTLS-ZEXPDT       = 'null'.
        LS_ITEMLIST-BCHDTLS-WRDT         = 'null'.
        IF  LS_ITEMLIST-BCHDTLS-ZNM   IS NOT INITIAL.
          LS_UPDATE-BCHDTLS = 'X'.
        ENDIF.

        LS_ATTRIBDTLS-ZNM         =  LC_NULL.
        LS_ATTRIBDTLS-VALU        =  LC_NULL.


        APPEND LS_ATTRIBDTLS TO LT_ATTRIBDTLS.
        LS_ITEMLIST-ATTRIBDTLS  = LT_ATTRIBDTLS.

        APPEND LS_ITEMLIST TO LT_ITEMLIST.



        LV_TOTAL_VAL  = LV_TOTAL_VAL  + LS_ITEMLIST-TOTITEMVAL.
        LV_ASSVAL     = LS_ITEMLIST-ASSAMT  + LV_ASSVAL.
        LV_CGSTVAL    = LS_ITEMLIST-CGSTAMT + LV_CGSTVAL.
        LV_SGSTVAL    = LS_ITEMLIST-SGSTAMT + LV_SGSTVAL.
        LV_IGSTVAL    = LS_ITEMLIST-IGSTAMT + LV_IGSTVAL.
        LV_DISCOUNT   = LS_ITEMLIST-DISCOUNT + LV_DISCOUNT.


        CLEAR: LS_ITEMLIST , LS_ATTRIBDTLS ,LS_KKURS.


        REFRESH : LT_ATTRIBDTLS.
      ENDLOOP.

      LS_FINAL-ITEMLIST = LT_ITEMLIST.

      REFRESH: LT_ITEMLIST.

***********************************************************
      "--ValDtls (Values Details)------------------
***********************************************************

      LS_FINAL-VALDTLS-ASSVAL       = LV_ASSVAL.
      LS_FINAL-VALDTLS-CGSTVAL      = LV_CGSTVAL.
      LS_FINAL-VALDTLS-SGSTVAL      = LV_SGSTVAL.
      LS_FINAL-VALDTLS-IGSTVAL      = LV_IGSTVAL.
      LS_FINAL-VALDTLS-ZCESVAL      = ''."lv_cesval.3
      LS_FINAL-VALDTLS-STCESVAL     = ''."lv_stcesval.
      LS_FINAL-VALDTLS-RNDOFFAMT    = LV_ROUNDOFF.
      LS_FINAL-VALDTLS-ZTOTINVVAL   = LV_TOTAL_VAL.
      LS_FINAL-VALDTLS-TOTINVVALFC  = ''.
*      ls_final-valdtls-invforcur     = lc_null.
      LS_UPDATE-VALDTLS = 'X'.

*** Avinash
      IF LS_VBRK-FKART = 'ZEXP'.
        IF LS_FINAL-VALDTLS-IGSTVAL IS NOT INITIAL.
          LS_FINAL-TRANDTLS-SUPTYP = 'EXPWP'.
        ELSEIF LS_FINAL-VALDTLS-IGSTVAL IS INITIAL.
          LS_FINAL-TRANDTLS-SUPTYP = 'EXPWOP'.
        ENDIF.
      ENDIF.



**end avi **
***********************************************************
      "--PayDtls (Pay Details)---------------------
***********************************************************
      LS_FINAL-PAYDTLS-ZNM        = ''.
      LS_FINAL-PAYDTLS-ACCDET     = LC_NULL.
      LS_FINAL-PAYDTLS-MODES      = LC_NULL.
      LS_FINAL-PAYDTLS-FININSBR   = LC_NULL.
      LS_FINAL-PAYDTLS-PAYTERM    = LC_NULL.
      LS_FINAL-PAYDTLS-PAYINSTR   = LC_NULL.
      LS_FINAL-PAYDTLS-CRTRN      = LC_NULL.
      LS_FINAL-PAYDTLS-DIRDR      = LC_NULL.
      LS_FINAL-PAYDTLS-CRDAY      = LC_NULL.
      LS_FINAL-PAYDTLS-PAIDAMT    = '0.00'.
      LS_FINAL-PAYDTLS-PAYMTDUE   = '0.00'.
      IF  LS_FINAL-PAYDTLS-ZNM   IS NOT INITIAL.
        LS_UPDATE-PAYDTLS = 'X'.
      ENDIF.

***********************************************************
      "--RefDtls (Ref Details)----------------------
***********************************************************

      DATA :
        LV_CURRY    TYPE VBRK-GJAHR,
        LV_FY(4)    TYPE C,
        LV_PERIV    TYPE PERIV VALUE 'V3',
        LV_INVSTDT  TYPE SY-DATUM,
        LV_INVENDDT TYPE SY-DATUM.


      CALL FUNCTION 'GM_GET_FISCAL_YEAR'
        EXPORTING
          I_DATE                     = LS_VBRK-FKDAT
          I_FYV                      = LV_PERIV
        IMPORTING
          E_FY                       = LV_FY
        EXCEPTIONS
          FISCAL_YEAR_DOES_NOT_EXIST = 1
          NOT_DEFINED_FOR_DATE       = 2
          OTHERS                     = 3.
      IF SY-SUBRC <> 0.
* Implement suitable error handling here
      ENDIF.

      MOVE LV_FY TO LV_CURRY.

      CALL FUNCTION 'FIRST_AND_LAST_DAY_IN_YEAR_GET'
        EXPORTING
          I_GJAHR        = LV_CURRY
          I_PERIV        = LV_PERIV
        IMPORTING
          E_FIRST_DAY    = LV_INVSTDT
          E_LAST_DAY     = LV_INVENDDT
        EXCEPTIONS
          INPUT_FALSE    = 1
          T009_NOTFOUND  = 2
          T009B_NOTFOUND = 3
          OTHERS         = 4.
      IF SY-SUBRC <> 0.
* Implement suitable error handling here
      ENDIF.

      CONCATENATE LV_INVSTDT+6(02) '/' LV_INVSTDT+4(02) '/' LV_INVSTDT(04)  INTO LS_FINAL-REFDTLS-DOCPERDDTLS-INVSTDT.
      CONCATENATE LV_INVENDDT+6(02) '/' LV_INVENDDT+4(02) '/' LV_INVENDDT(04)  INTO LS_FINAL-REFDTLS-DOCPERDDTLS-INVENDDT.


      LS_FINAL-REFDTLS-INVRM        = LC_NULL.

      LS_PRECDOCDTLS-INVNO          = ''.
      LS_PRECDOCDTLS-INVDT          = LC_NULL.
      LS_PRECDOCDTLS-OTHREFNO       = LC_NULL.
      IF LS_PRECDOCDTLS-INVNO IS NOT INITIAL.
        LS_UPDATE-PRECDOCDTLS = 'X'.
      ENDIF.
      LS_CONTRDTLS-RECADVREFR       = LC_NULL.
      LS_CONTRDTLS-RECADVDT         = LC_NULL.
      LS_CONTRDTLS-TENDREFR         = LC_NULL.
      LS_CONTRDTLS-CONTRREFR        = LC_NULL.
      LS_CONTRDTLS-EXTREFR          = LC_NULL.
      LS_CONTRDTLS-PROJREFR         = LC_NULL.
      LS_CONTRDTLS-POREFR           = LC_NULL.
      LS_CONTRDTLS-POREFDT          = LC_NULL.
      IF LS_CONTRDTLS-RECADVREFR  IS NOT INITIAL.
        LS_UPDATE-CONTRDTLS = 'X'.
      ENDIF.
      APPEND LS_CONTRDTLS TO LT_CONTRDTLS.
      LS_FINAL-REFDTLS-CONTRDTLS  = LT_CONTRDTLS.
*      ls_final-refdtls-contrdtls    = ls_contrdtls.

      APPEND LS_PRECDOCDTLS TO LT_PRECDOCDTLS.
      LS_FINAL-REFDTLS-PRECDOCDTLS  = LT_PRECDOCDTLS.
*      ls_final-refdtls-precdocdtls  = ls_precdocdtls.

      CLEAR: LT_PRECDOCDTLS,LT_CONTRDTLS,LS_CONTRDTLS,LS_PRECDOCDTLS.

      IF LS_FINAL-REFDTLS-DOCPERDDTLS-INVSTDT IS NOT INITIAL.
*        ls_update-refdtls = 'X'.              ???????????????????????????
      ENDIF.

***********************************************************
*      ---ExpDtls------------------------------------ ---
***********************************************************

      READ TABLE LT_LIKP INTO LS_LIKP WITH KEY  VBELN = LS_VBRP-VGBEL.
      IF SY-SUBRC EQ 0.
        READ TABLE LT_VBPA INTO LS_VBPA WITH KEY VBELN  = LS_LIKP-VBELN.
        IF SY-SUBRC EQ 0.
          READ TABLE LT_KNA1_EXP INTO LS_KNA1_EXP WITH KEY KUNNR = LS_VBPA-KUNNR.
          IF SY-SUBRC EQ 0.
            LS_FINAL-EXPDTLS-PORT     = LS_KNA1_EXP-LOCCO.
          ENDIF.
        ENDIF.
      ENDIF.


      LS_FINAL-EXPDTLS-SHIPBNO  =  "ls_vbrk-xblnr.
      LS_FINAL-EXPDTLS-SHIPBDT  = "lv_date.
      LS_FINAL-EXPDTLS-REFCLM   = ''.
      LS_FINAL-EXPDTLS-EXPDUTY  = 0.

      IF LS_FINAL-EXPDTLS-SHIPBNO IS INITIAL.
        LS_FINAL-EXPDTLS-SHIPBNO  = LC_NULL.
      ENDIF.

      IF LS_FINAL-EXPDTLS-SHIPBDT IS INITIAL.
        LS_FINAL-EXPDTLS-SHIPBDT  = LC_NULL.
      ENDIF.

      IF LS_FINAL-EXPDTLS-REFCLM IS INITIAL.
        LS_FINAL-EXPDTLS-REFCLM = LC_NULL.
      ENDIF.

      LS_FINAL-EXPDTLS-FORCUR   = LS_VBRK-WAERK.

      IF LS_VBRK-LAND1 IS INITIAL.
        LS_FINAL-EXPDTLS-CNTCODE  = LC_NULL.
      ELSE.
        LS_FINAL-EXPDTLS-CNTCODE  = LS_VBRK-LAND1.
      ENDIF.

      IF LS_FINAL-EXPDTLS-PORT IS NOT INITIAL.
        LS_UPDATE-EXPDTLS = 'X'.
      ENDIF.

************************************************************************
      "--Addldocdtls--------------------------------------------
************************************************************************
      LS_ADDLDOCDTLS-URL  = LC_NULL.
      LS_ADDLDOCDTLS-DOCS = LC_NULL.
      LS_ADDLDOCDTLS-INFODTLS = LC_NULL.
      APPEND LS_ADDLDOCDTLS TO LT_ADDLDOCDTLS.
      LS_FINAL-ADDLDOCDTLS = LT_ADDLDOCDTLS.
      CLEAR : LS_ADDLDOCDTLS,LT_ADDLDOCDTLS.

************************************************************************
      "----Ewbdtls(E-way Bill)------------------------------------------
************************************************************************

      DATA: LS_EWAY_DATE  TYPE STRING.
      DATA: LV_TRANS_MODE TYPE STRING.

      READ TABLE LT_VBRP INTO LS_VBRP WITH KEY VBELN  = LS_VBRK-VBELN.
      IF SY-SUBRC EQ 0.

        READ TABLE LT_LIKP_EWAY INTO DATA(LS_LIKP_EWAY) WITH KEY  VBELN = LS_VBRP-VGBEL.
        IF SY-SUBRC EQ 0.
          LS_FINAL-EWBDTLS-VEHNO        =  LS_LIKP_EWAY-BOLNR.
        ENDIF.
        READ TABLE LT_VBPA_EWAY INTO LS_VBPA_EWAY WITH KEY VBELN = LS_VBRP-VGBEL.
        IF SY-SUBRC EQ 0.
          READ TABLE LT_LFA1_EWAY INTO LS_LFA1_EWAY WITH KEY LIFNR = LS_VBPA_EWAY-LIFNR.
          IF SY-SUBRC EQ 0.
            LS_FINAL-EWBDTLS-TRANSID      = LS_LFA1_EWAY-STCD3.
            LS_FINAL-EWBDTLS-TRANSNAME    = LS_LFA1_EWAY-NAME1.
          ENDIF.
        ENDIF.
      ENDIF.



      READ TABLE LT_ZEWAY_TAB INTO LS_ZEWAY_TAB WITH KEY VBELN = LS_VBRK-VBELN.
      IF SY-SUBRC EQ 0.

        IF LS_FINAL-EWBDTLS-VEHNO IS INITIAL.
          LS_FINAL-EWBDTLS-VEHNO        = LS_ZEWAY_TAB-VEHICAL_NO.
        ENDIF.

        IF LS_FINAL-EWBDTLS-TRANSID IS INITIAL.
          LS_FINAL-EWBDTLS-TRANSID      = LS_ZEWAY_TAB-TRANS_ID.
        ENDIF.

        LS_FINAL-EWBDTLS-DISTANCE     = LS_ZEWAY_TAB-DISTANCE.

        IF LS_ZEWAY_TAB-TRANS_DOC IS NOT INITIAL.
          LS_FINAL-EWBDTLS-TRANSDOCNO   = LS_ZEWAY_TAB-TRANS_DOC.
        ELSE.
          LS_FINAL-EWBDTLS-TRANSDOCNO   = 'null'.
        ENDIF.

        IF LS_FINAL-EWBDTLS-TRANSNAME IS INITIAL.
          LS_FINAL-EWBDTLS-TRANSNAME   = LS_ZEWAY_TAB-TRANS_NAME.
        ENDIF.

        IF LS_ZEWAY_TAB-DOC_DT IS NOT INITIAL.
          CONCATENATE LS_ZEWAY_TAB-DOC_DT+6(2) LS_ZEWAY_TAB-DOC_DT+4(2) LS_ZEWAY_TAB-DOC_DT+0(4) INTO LS_EWAY_DATE  SEPARATED BY '/'.
        ELSE.
          LS_EWAY_DATE = 'null'.
        ENDIF.

        LS_FINAL-EWBDTLS-TRANSDOCDT   = LS_EWAY_DATE.
        LS_FINAL-EWBDTLS-VEHTYPE      = LS_ZEWAY_TAB-VEHICAL_TYPE+0(1).

        CASE LS_ZEWAY_TAB-TRNS_MD.
          WHEN 'Road'.
            LV_TRANS_MODE = 1.
          WHEN 'Rail'.
            LV_TRANS_MODE = 2.
          WHEN 'Air'.
            LV_TRANS_MODE = 3.
          WHEN 'Ship'.
            LV_TRANS_MODE = 4.
          WHEN OTHERS.
        ENDCASE.
        LS_FINAL-EWBDTLS-TRANSMODE    = LV_TRANS_MODE.

      ENDIF.
      IF LV_UCOMM = '&IRNEW'.
        LS_UPDATE-EWBDTLS = 'X'.
      ENDIF.

      APPEND LS_FINAL TO LT_FINAL.
      CLEAR: LV_ASSVAL, LV_CGSTVAL, LV_SGSTVAL, LV_IGSTVAL,LV_TOTAL_VAL,LV_ROUNDOFF.

    ELSE.
*    MESSAGE 'Posting is not completed' TYPE 'E'.
      LS_RETMSG-ID = 'E'.
      LS_RETMSG-MESSAGE = 'Posting is not completed'.
      APPEND LS_RETMSG TO LT_RETMSG.
      LV_ERROR = 'X'.
      CLEAR LS_RETMSG.
      EXIT.
      LEAVE LIST-PROCESSING.
    ENDIF.
    CLEAR : LV_CURRY, LV_FY.
    CLEAR : LS_SEL_ADDR,LS_DIS_ADDR,LS_BUY_ADDR,LS_SHP_ADDR.
  ENDLOOP.

  CLEAR : LS_SEL_ADDR,LS_DIS_ADDR,LS_BUY_ADDR,LS_SHP_ADDR.

  IT_FINAL = LT_FINAL.



ENDFORM.

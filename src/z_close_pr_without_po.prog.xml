   <LONGTEXTS>
    <item>
     <DOKIL>
      <ID>RE</ID>
      <OBJECT>Z_CLOSE_PR_WITHOUT_PO</OBJECT>
      <LANGU>E</LANGU>
      <TYP>E</TYP>

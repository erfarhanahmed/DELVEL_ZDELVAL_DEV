   OTHERS          = 3
  .
IF sy-subrc <> 0.
* Implement suitable error handling here
ENDIF.
*GV_AMOUNT5 = GV_AMOUNT2-WORD.
*amt2       = GV_AMOUNT2-DECWORD.



if P_WAERS = 'USD'.
IF GV_AMOUNT2-DECWORD NE 'ZERO'.
 CONCATENATE  GV_AMOUNT2-word'DOLLARS' 'AND'
             GV_AMOUNT2-DECWORD'CENTS ' INTO tax_amount SEPARATED BY SPACE.
 ELSEIF
    GV_AMOUNT2-DECWORD = 'ZERO' .
    CONCATENATE  GV_AMOUNT2-word'DOLLARS'
              INTO tax_amount SEPARATED BY SPACE.

 ENDIF.
elseif P_WAERS = 'SAR'.
      IF GV_AMOUNT2-DECWORD = 'ZERO'.
     CONCATENATE 'SAUDI RIYAL' GV_AMOUNT2-WORD 'ONLY' INTO tax_amount SEPARATED BY SPACE.
*     ENDIF.

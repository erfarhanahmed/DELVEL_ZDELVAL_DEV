     ELSE.
     CONCATENATE 'SAUDI RIYAL' GV_AMOUNT2-WORD 'AND'
     GV_AMOUNT2-DECWORD 'HALALAS ONLY' INTO tax_amount SEPARATED BY SPACE.
     endif.

 elseif P_WAERS = 'INR'.

              'Production Date'
              'SO QTY.'
              'Delivery Date'
              'Customer Item Code'
              'Production Order No.'
              'QTY.'
              'Confirmation Date'
              'Inspection Date'
              'Production Amt.'
              'Rate'
              'Standard Cost'
              'Series'
              'Size'
              'MOC'
              'Type'
              'Storage Loc.'
              'MRP Date'
              'Order Release Date'
              'Currency'
              'Current Exchange Rate'
              'Sales Value(DC)'

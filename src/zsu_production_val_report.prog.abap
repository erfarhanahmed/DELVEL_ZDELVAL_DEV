FORM CVS_HEADER  USING    PD_CSV.
  DATA: L_FIELD_SEPERATOR.
  L_FIELD_SEPERATOR = CL_ABAP_CHAR_UTILITIES=>HORIZONTAL_TAB.
  CONCATENATE 'MRP Controller'
              'Brand'
              'Sales Order No.'
              'Line Item'
              'Sales Office'
              'Material No.'

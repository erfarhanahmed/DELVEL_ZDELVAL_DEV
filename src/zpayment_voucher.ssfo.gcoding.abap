

SELECT *
FROM BSEG
INTO TABLE LT_BSEG
WHERE BUKRS = P_BUKRS
AND BELNR = P_BELNR
AND GJAHR = P_GJAHR
AND KOART = 'S'
AND SHKZG = 'S'
AND KTOSL = 'JIC'.

 IF LT_BSEG IS INITIAL.
 SELECT *
FROM BSEG
INTO TABLE LT_BSEG
WHERE BUKRS = P_BUKRS
AND BELNR = P_BELNR
AND GJAHR = P_GJAHR
AND KOART = 'S'
AND SHKZG = 'S'
AND KTOSL = 'JII'.
 ENDIF.
IF LT_BSEG is INITIAL.
SELECT *
FROM BSEG
INTO TABLE LT_BSEG
WHERE BUKRS = P_BUKRS
AND BELNR = P_BELNR
AND GJAHR = P_GJAHR
AND KOART = 'K'.
ENDIF.
SELECT SINGLE GSBER SGTXT
FROM BSEG
INTO (PLANT,SGTXT)
WHERE BUKRS = P_BUKRS
AND BELNR = P_BELNR
AND GJAHR = P_GJAHR
AND BUZEI = '1'.











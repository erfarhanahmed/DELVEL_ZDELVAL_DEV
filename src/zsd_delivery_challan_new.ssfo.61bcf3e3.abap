
CLEAR:LV_STEUC.

SELECT SINGLE STEUC
          FROM MARC
          INTO LV_STEUC
          WHERE MATNR = GS_MSEG-MATNR
          AND WERKS = GS_MSEG-WERKS.

*IF LV_STEUC1 IS NOT INITIAL.
*
*  LV_STEUC = LV_STEUC1.
*ELSE.
*  LV_STEUC = 'NULL'.
*ENDIF.

GV_QNTY = GS_MSEG-MENGE.

GV_QNTY1 = GV_QNTY.

CONDENSE GV_QNTY1 .

CONCATENATE GV_QNTY1 GS_MSEG-MEINS INTO LV_QY SEPARATED BY space.














SELECT SINGLE BLDAT
FROM BKPF
INTO BLDAT
WHERE BUKRS = '1000'
AND BELNR = P_BELNR
AND GJAHR = P_GJAHR.

SELECT SINGLE kunnr
FROM BSEG
INTO KUNNR
WHERE BUKRS = '1000'
AND BELNR = P_BELNR
AND GJAHR = P_GJAHR
AND KOART = 'D'.

IF KUNNR IS NOT INITIAL.
SELECT SINGLE *
FROM KNA1
INTO LS_KNA1
WHERE KUNNR = KUNNR.
ENDIF.

SELECT SINGLE BEZEI
FROM T005U
INTO STATE
WHERE SPRAS = SY-LANGU
AND LAND1 = LS_KNA1-LAND1
AND BLAND = LS_KNA1-REGIO.

SELECT SINGLE gst_region
       FROM   zgst_region
       INTO   gv_reg
       WHERE  bezei = STATE.

CONCATENATE LS_KNA1-ORT01
            STATE
       INTO ADDRESS SEPARATED BY SPACE.

GST = LS_KNA1-STCD3.

SELECT SINGLE *
       FROM adrc
       INTO gs_adrc
       WHERE addrnumber = ls_kna1-adrnr.

IF NOT gs_adrc-POST_CODE1 is INITIAL.
  CONCATENATE 'PIN-' gs_adrc-post_code1 INTO gv_pin.
ENDIF.















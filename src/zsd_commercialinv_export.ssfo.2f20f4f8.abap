DATA: L_ALAND TYPE HLAND.
IF G_KUNNR EQ IS_BIL_INVOICE-HD_GEN-SOLD_TO_PARTY.
  G_CONSIGNEE = '1'.
ELSE.
  SELECT SINGLE ALAND FROM EIKP
  INTO L_ALAND
  WHERE REFNR = IS_BIL_INVOICE-HD_GEN-BIL_NUMBER.
  IF SY-SUBRC = 0.
    SELECT SINGLE LANDX FROM T005T INTO G_LANDX2
    WHERE LAND1 = L_ALAND AND
    SPRAS = 'EN'.
  ENDIF.
ENDIF.


















SELECT *
FROM BSEG
INTO TABLE LT_BSEG
WHERE BUKRS = P_BUKRS
AND BELNR = P_BELNR
AND GJAHR = P_GJAHR
AND KOART = 'S'
AND SHKZG = 'S'
AND KTOSL = 'JOC'.

 IF LT_BSEG IS INITIAL.
 SELECT *
FROM BSEG
INTO TABLE LT_BSEG
WHERE BUKRS = P_BUKRS
AND BELNR = P_BELNR
AND GJAHR = P_GJAHR
AND KOART = 'S'
AND SHKZG = 'S'
AND KTOSL = 'JOI'.
 ENDIF.

SELECT SINGLE GSBER SGTXT
FROM BSEG
INTO (PLANT,SGTXT)
WHERE BUKRS = P_BUKRS
AND BELNR = P_BELNR
AND GJAHR = P_GJAHR
AND BUZEI = '1'.












